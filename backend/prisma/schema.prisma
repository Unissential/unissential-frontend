// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  password            String
  university          String
  isVerified          Boolean   @default(false)
  verificationToken   String?   @unique
  verificationExpires DateTime?
  profilePicture      String?
  bio                 String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  listings            Listing[]
  marketplaceProducts MarketplaceProduct[]
  roommateProfile     RoommateProfile?
  savedItems          SavedItem[]
  sentMessages        Message[] @relation("sender")
  conversations       ConversationParticipant[]
  notifications       Notification[]

  @@index([email])
}

// Leasing Listing model
model Listing {
  id          String    @id @default(cuid())
  title       String
  description String
  price       Float
  location    String
  latitude    Float?
  longitude   Float?
  images      String[] // JSON array of image URLs
  amenities   String[] // JSON array of amenities
  bedrooms    Int
  bathrooms   Int
  furnished   Boolean   @default(false)
  leaseStart  DateTime?
  leaseEnd    DateTime?
  petFriendly Boolean   @default(false)
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  savedBy     SavedItem[]

  @@index([ownerId])
  @@index([location])
}

// Roommate Profile model
model RoommateProfile {
  id           String   @id @default(cuid())
  age          Int
  university   String
  major        String?
  budget       Float
  interests    String[] // JSON array of interests
  sleepSchedule String  // "early_bird" | "night_owl" | "flexible"
  cleanliness  String   // "very_clean" | "somewhat_clean" | "flexible"
  smoking      Boolean  @default(false)
  partying     Boolean  @default(false)
  bio          String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  savedBy      SavedItem[]

  @@index([userId])
}

// Marketplace Product model
model MarketplaceProduct {
  id        String   @id @default(cuid())
  title     String
  description String
  price     Float
  condition String   // "like_new" | "excellent" | "good" | "fair"
  category  String   // "electronics" | "textbooks" | "furniture" | etc
  images    String[] // JSON array of image URLs
  seller    User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sellerId  String
  views     Int      @default(0)
  interested Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  savedBy   SavedItem[]

  @@index([sellerId])
  @@index([category])
}

// Conversation model
model Conversation {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  participants  ConversationParticipant[]
  messages      Message[]
}

// Conversation Participant (join table)
model ConversationParticipant {
  id             String       @id @default(cuid())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String

  @@unique([userId, conversationId])
  @@index([userId])
  @@index([conversationId])
}

// Message model
model Message {
  id             String       @id @default(cuid())
  content        String
  sender         User         @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId       String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  createdAt      DateTime     @default(now())

  @@index([senderId])
  @@index([conversationId])
}

// Notification model
model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   // "message" | "tour" | "listing" | "roommate" | "product"
  isRead    Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Saved Items model (polymorphic - can save listings, roommates, or products)
model SavedItem {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  itemType  String   // "listing" | "roommate" | "product"
  itemId    String   // ID of the listing, roommate profile, or product
  listing   Listing? @relation(fields: [itemId], references: [id], onDelete: Cascade, ignoreRelationScopeFail: true)
  roommate  RoommateProfile? @relation(fields: [itemId], references: [id], onDelete: Cascade, ignoreRelationScopeFail: true)
  product   MarketplaceProduct? @relation(fields: [itemId], references: [id], onDelete: Cascade, ignoreRelationScopeFail: true)
  createdAt DateTime @default(now())

  @@unique([userId, itemType, itemId])
  @@index([userId])
  @@index([itemType])
}
